<!DOCTYPE html>
<html lang="ru">
<head>
  <meta charset="UTF-8" />
  <title>Redirecting to WhatsApp...</title>

  <script async src="https://www.googletagmanager.com/gtag/js?id=G-W3L0DG2NNN"></script>
  <script>
    window.dataLayer = window.dataLayer || [];
    function gtag(){dataLayer.push(arguments);}
    gtag('js', new Date());
    gtag('config', 'G-W3L0DG2NNN');
  </script>

  <script>
    // ЗАМЕНИ НОМЕР НИЖЕ (только цифры, без +)
    const phone = "79991234567"; 
    
    const waApp = "whatsapp://send?phone=" + phone;
    const waWeb = "https://wa.me/" + phone;

    function openWhatsApp() {
      // Фиксируем событие для аналитики
      gtag('event', 'redirect_to_whatsapp', {
        event_category: 'QR',
        event_label: 'whatsapp_contact',
        transport_type: 'beacon'
      });

      // Пытаемся открыть приложение напрямую
      window.location.href = waApp;

      // Если приложение не установлено или не открылось — через 1.5 сек шлем в браузерную версию
      setTimeout(function() {
        window.location.href = waWeb;
      }, 1500);
    }

    window.onload = openWhatsApp;
  </script>
</head>
<body>
  <p>Перенаправляем в WhatsApp...</p>
</body>
</html>
